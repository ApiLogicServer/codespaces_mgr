    "test_data_sqlite": "-- SQL INSERT statements for test data\\nINSERT INTO customer (id, balance, credit_limit) VALUES (1, 1000, 5000);\\nINSERT INTO order (id, customer_id, amount_total, date_shipped, notes) VALUES (1, 1, 300, '2023-01-01', 'Priority order');\\nINSERT INTO item (id, order_id, quantity, unit_price, amount) VALUES (1, 1, 10, 30, 300);\\nINSERT INTO product (id, unit_price) VALUES (1, 30);\\nINSERT INTO customer (id, balance, credit_limit) VALUES (2, 1500, 5000);\\nINSERT INTO order (id, customer_id, amount_total, date_shipped, notes) VALUES (2, 2, 450, '2023-02-15', 'Urge shipment');\\nINSERT INTO item (id, order_id, quantity, unit_price, amount) VALUES (2, 2, 15, 30, 450);\\nINSERT INTO product (id, unit_price) VALUES (2, 30);\\nINSERT INTO customer (id, balance, credit_limit) VALUES (3, 2000, 5000);\\nINSERT INTO order (id, customer_id, amount_total, date_shipped, notes) VALUES (3, 3, 750, '2023-03-10', 'Regular shipment');\\nINSERT INTO item (id, order_id, quantity, unit_price, amount) VALUES (3, 3, 25, 30, 750);\\nINSERT INTO product (id, unit_price) VALUES (3, 30);\\nINSERT INTO customer (id, balance, credit_limit) VALUES (4, 2500, 5000);\\nINSERT INTO order (id, customer_id, amount_total, date_shipped, notes) VALUES (4, 4, 900, '2023-04-05', 'Delayed shipment');\\nINSERT INTO item (id, order_id, quantity, unit_price, amount) VALUES (4, 4, 30, 30, 900);\\nINSERT INTO product (id, unit_price) VALUES (4, 30);",
