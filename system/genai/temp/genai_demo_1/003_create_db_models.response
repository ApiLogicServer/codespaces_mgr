{
    "models": [
        {
            "classname": "Customer",
            "code": "class Customer(Base):\\n    __tablename__ = 'customer'\\n    id = Column(Integer, primary_key=True, autoincrement=True)\\n    balance = Column(DECIMAL)\\n    credit_limit = Column(DECIMAL)",
            "description": "This class defines the Customer entity.",
            "name": "Customer"
        },
        {
            "classname": "Order",
            "code": "class Order(Base):\\n    __tablename__ = 'order'\\n    id = Column(Integer, primary_key=True, autoincrement=True)\\n    customer_id = Column(Integer, ForeignKey('customer.id'))\\n    amount_total = Column(DECIMAL)\\n    date_shipped = Column(DateTime)\\n    notes = Column(String)",
            "description": "This class defines the Order entity with a notes field.",
            "name": "Order"
        },
        {
            "classname": "Item",
            "code": "class Item(Base):\\n    __tablename__ = 'item'\\n    id = Column(Integer, primary_key=True, autoincrement=True)\\n    order_id = Column(Integer, ForeignKey('order.id'))\\n    quantity = Column(Integer)\\n    unit_price = Column(DECIMAL)\\n    amount = Column(DECIMAL)",
            "description": "This class defines the Item entity.",
            "name": "Item"
        },
        {
            "classname": "Product",
            "code": "class Product(Base):\\n    __tablename__ = 'product'\\n    id = Column(Integer, primary_key=True, autoincrement=True)\\n    unit_price = Column(DECIMAL)",
            "description": "This class defines the Product entity for storing product information.",
            "name": "Product"
        }
    ],
    "rules": [
        {
            "name": "Check Credit - 1",
            "description": "Customer's balance must be less than their credit limit.",
            "use_case": "Check Credit",
            "entity": "Customer",
            "code": "Rule.constraint(validate=Customer, as_condition=lambda row: row.balance < row.credit_limit, error_msg=\"Customer balance ({row.balance}) exceeds credit limit ({row.credit_limit})\")"
        },
        {
            "name": "Check Credit - 2",
            "description": "Customer's balance is the sum of unshipped Order amounts.",
            "use_case": "Check Credit",
            "entity": "Customer",
            "code": "Rule.sum(derive=Customer.balance, as_sum_of=Order.amount_total, where=lambda row: row.date_shipped is None)"
        },
        {
            "name": "Check Credit - 3",
            "description": "Order's total amount is the sum of its Item amounts.",
            "use_case": "Check Credit",
            "entity": "Order",
            "code": "Rule.sum(derive=Order.amount_total, as_sum_of=Item.amount)"
        },
        {
            "name": "Check Credit - 4",
            "description": "Item's amount is calculated as quantity times unit price.",
            "use_case": "Check Credit",
            "entity": "Item",
            "code": "Rule.formula(derive=Item.amount, as_expression=lambda row: row.quantity * row.unit_price)"
        },
        {
            "name": "Check Credit - 5",
            "description": "Item's unit price is copied from the Product's unit price.",
            "use_case": "Check Credit",
            "entity": "Item",
            "code": "Rule.copy(derive=Item.unit_price, from_parent=Product.unit_price)"
        },
        {
            "name": "App Integration",
            "description": "Send the Order to Kafka if the date_shipped is not None.",
            "use_case": "App Integration",
            "entity": "Order",
            "code": "Rule.after_flush_row_event(on_class=Order, calling=kafka_producer.send_row_to_kafka, if_condition=lambda row: row.date_shipped is not None, with_args={\"topic\": \"order_shipping\"})"
        }
    ],
